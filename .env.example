# ============================================================
# SHU-HAUL — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=3000

# Twilio credentials
# Find these at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio phone number to send FROM (must be provisioned in your account)
# Format: E.164, e.g. +15550001234
TWILIO_FROM_NUMBER=+15550001234

# The driver's phone number — where ride alerts will be sent
# Format: E.164, e.g. +15559876543
DRIVER_PHONE_NUMBER=+15559876543
